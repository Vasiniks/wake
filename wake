#!/usr/bin/env bash
#
# wake — keep an Apple Silicon MacBook running with the lid CLOSED, on battery,
#        with no external display, keyboard, mouse, or power required.
#
# The whole trick is one built-in macOS command:  pmset -b disablesleep 1
# which tells the power manager to ignore the lid switch while on battery.
# wake wraps that with an idle-sleep guard (caffeinate) and, importantly,
# an automatic-revert safety net so you never leave your Mac in a state where
# it refuses to sleep after you're done.
#
# MIT License. No warranty. See README.
#
set -euo pipefail

VERSION="1.0.0"
STATE_DIR="${HOME}/.wake"
PID_FILE="${STATE_DIR}/caffeinate.pid"
WATCHDOG_PID_FILE="${STATE_DIR}/watchdog.pid"
KEEPALIVE_PID_FILE="${STATE_DIR}/keepalive.pid"

mkdir -p "$STATE_DIR"

# ---- helpers ---------------------------------------------------------------

err()  { printf 'wake: %s\n' "$*" >&2; }
info() { printf '%s\n' "$*"; }

require_macos() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    err "this tool only runs on macOS."
    exit 1
  fi
}

# Is disablesleep currently on? pmset -g returns "SleepDisabled  1" when active.
is_disabled() {
  pmset -g | awk '/SleepDisabled/{print $2}' | grep -q '^1$'
}

caffeinate_running() {
  [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

start_caffeinate() {
  # -i prevents idle system sleep (works on battery); -m keeps disk awake.
  # Without this, disablesleep stops LID sleep but the system could still
  # idle-sleep after the display-off timeout.
  caffeinate -im &
  echo $! > "$PID_FILE"
}

stop_caffeinate() {
  if caffeinate_running; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
}

# Keep the sudo timestamp fresh for the length of a timed session. Without
# this, the auto-revert watchdog fires long after the cached credential has
# expired and — running detached, with no terminal to prompt on — its
# `sudo pmset` silently fails, leaving the Mac unable to sleep. That would
# defeat the entire point of the timer, so the safety net must stay armed.
start_sudo_keepalive() {
  local minutes="$1"
  (
    # Refresh a little past the deadline, then let the cache expire on its own
    # so we never hold credentials warm indefinitely.
    local deadline=$(( $(date +%s) + minutes * 60 + 30 ))
    while [[ "$(date +%s)" -lt "$deadline" ]]; do
      sudo -n -v 2>/dev/null || exit 0   # cache gone (e.g. caching disabled) → give up
      sleep 60
    done
  ) &
  echo $! > "$KEEPALIVE_PID_FILE"
}

stop_sudo_keepalive() {
  if [[ -f "$KEEPALIVE_PID_FILE" ]]; then
    kill "$(cat "$KEEPALIVE_PID_FILE")" 2>/dev/null || true
    rm -f "$KEEPALIVE_PID_FILE"
  fi
}

# ---- commands --------------------------------------------------------------

cmd_on() {
  require_macos
  local minutes="${1:-0}"   # optional auto-revert timeout in minutes; 0 = none

  if ! [[ "$minutes" =~ ^[0-9]+$ ]]; then
    err "minutes must be a whole number (got: '$minutes'). Try: wake on 90"
    exit 1
  fi

  info "Enabling closed-lid mode (requires admin password)…"
  sudo pmset -b disablesleep 1

  start_caffeinate

  if [[ "$minutes" -gt 0 ]]; then
    # Watchdog: auto-revert after N minutes so a forgotten session can't
    # keep the Mac awake (and hot) indefinitely in your bag. The keepalive
    # guarantees the watchdog can still `sudo` when it fires (see above).
    start_sudo_keepalive "$minutes"
    ( sleep $(( minutes * 60 )); "$0" off >/dev/null 2>&1 ) &
    echo $! > "$WATCHDOG_PID_FILE"
    info "ON. Will auto-revert after ${minutes} min. Close the lid whenever."
  else
    info "ON. Closed-lid mode active on battery. Run 'wake off' when done."
  fi

  cat <<'NOTE'

  ⚠  Heat: with the lid shut and no external display, a busy CPU traps heat
     between screen and keyboard. Don't bury a heavy job in a sealed, padded
     bag for long. Give it some airflow.
NOTE
}

cmd_off() {
  require_macos
  info "Reverting to normal sleep behavior…"
  sudo pmset -b disablesleep 0
  stop_caffeinate
  stop_sudo_keepalive

  if [[ -f "$WATCHDOG_PID_FILE" ]]; then
    kill "$(cat "$WATCHDOG_PID_FILE")" 2>/dev/null || true
    rm -f "$WATCHDOG_PID_FILE"
  fi
  info "OFF. Your Mac will sleep normally when the lid closes."
}

cmd_status() {
  require_macos
  if is_disabled; then
    info "closed-lid mode: ON  (lid switch is being ignored on battery)"
  else
    info "closed-lid mode: OFF (normal — closing the lid sleeps the Mac)"
  fi
  if caffeinate_running; then
    info "idle guard:      running (pid $(cat "$PID_FILE"))"
  else
    info "idle guard:      not running"
  fi
  if [[ -f "$WATCHDOG_PID_FILE" ]] && kill -0 "$(cat "$WATCHDOG_PID_FILE")" 2>/dev/null; then
    info "auto-revert:     armed (pid $(cat "$WATCHDOG_PID_FILE"))"
  fi
}

cmd_help() {
  cat <<EOF
wake $VERSION — run your MacBook lid-closed, on battery, no dongle.

USAGE
  wake on [MINUTES]   enable closed-lid mode; optional auto-revert timer
  wake off            disable and return to normal sleep
  wake status         show current state
  wake help           this text

EXAMPLES
  wake on             keep running until you turn it off
  wake on 90          keep running for 90 min, then auto-revert (safer)
  wake off            done — sleep normally again

Requires an admin password (uses sudo pmset). macOS / Apple Silicon.
EOF
}

# ---- dispatch --------------------------------------------------------------

case "${1:-help}" in
  on)     shift; cmd_on "${1:-0}" ;;
  off)    cmd_off ;;
  status) cmd_status ;;
  -v|--version) echo "wake $VERSION" ;;
  help|-h|--help|*) cmd_help ;;
esac
